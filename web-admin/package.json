{
    "name":  "web-admin",
    "version":  "0.0.1-test.1",
    "scripts":  {
                    "ng":  "ng",
                    "start":  "ng serve",
                    "build":  "ng build",
                    "watch":  "ng build --watch --configuration development",
                    "test":  "ng test",
                    "build:exe":  "ng build \u0026\u0026 electron-builder --win"
                },
    "private":  true,
    "packageManager":  "npm@11.8.0",
    "dependencies":  {
                         "@angular/common":  "^21.2.0",
                         "@angular/compiler":  "^21.2.0",
                         "@angular/core":  "^21.2.0",
                         "@angular/forms":  "^21.2.0",
                         "@angular/platform-browser":  "^21.2.0",
                         "@angular/router":  "^21.2.0",
                         "rxjs":  "~7.8.0",
                         "tslib":  "^2.3.0"
                     },
    "devDependencies":  {
                            "@angular/build":  "^21.2.6",
                            "@angular/cli":  "^21.2.6",
                            "@angular/compiler-cli":  "^21.2.0",
                            "@iconify-json/ic":  "^1.2.4",
                            "@iconify/tailwind":  "^1.2.0",
                            "@tailwindcss/postcss":  "^4.2.2",
                            "autoprefixer":  "^10.4.27",
                            "daisyui":  "^4.12.24",
                            "electron":  "^41.1.1",
                            "electron-builder":  "^26.8.1",
                            "jsdom":  "^28.0.0",
                            "postcss":  "^8.5.8",
                            "prettier":  "^3.8.1",
                            "tailwindcss":  "^3.4.19",
                            "tailwindcss-animate":  "^1.0.7",
                            "typescript":  "~5.9.2",
                            "vitest":  "^4.0.8"
                        },
    "build":  {
                  "directories":  {
                                      "output":  "release"
                                  },
                  "files":  [
                                "dist/web-admin/browser/**/*",
                                "main.js"
                            ],
                  "productName":  "TuColmadoRD",
                  "publish":  [
                                  {
                                      "provider":  "github",
                                      "owner":  "odimsom",
                                      "repo":  "TuColmadoRD.Frontend"
                                  }
                              ],
                  "win":  {
                              "target":  "nsis"
                          },
                  "appId":  "com.tucolmadord.admin",
                  "nsis":  {
                               "oneClick":  false,
                               "artifactName":  "TuColmadoRD-Setup.exe",
                               "allowToChangeInstallationDirectory":  true
                           }
              }
}
